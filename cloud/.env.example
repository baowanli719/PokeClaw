# PokeClaw Cloud Bridge — Environment Configuration
# Copy this file to .env and fill in real values.

# ─── Required ───────────────────────────────────────────────────────────────

# OceanBase connection string (MySQL-compatible, async driver)
# Format: mysql+asyncmy://<user>:<password>@<host>:<port>/<database>
OB_DSN=mysql+asyncmy://dashboard:password@host:3306/dashboard

# Device bearer tokens (comma-separated, one per phone)
DEVICE_TOKENS=token_phone_01,token_phone_02

# Admin bearer token for REST control plane
ADMIN_TOKEN=change_me_admin_token

# ─── Optional ───────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Heartbeat interval the server expects from devices (seconds)
HEARTBEAT_INTERVAL_SEC=30

# Seconds without any frame before a device is considered stale
STALE_TIMEOUT_SEC=90

# How often to check for timed-out tasks (seconds)
DEADLINE_CHECK_INTERVAL_SEC=10
